[Unit]
Description=ShowMaster V2 — Live show control for RocketShow
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__INSTALL_DIR__
ExecStart=/usr/bin/node server/src/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=SM_PORT=3000

[Install]
WantedBy=multi-user.target
